# SF Learning Platform — Environment Configuration
# Copy this to .env and fill in your values

# OpenAI API key for AI tutor (GPT-5.4)
OPENAI_API_KEY=sk-proj-your-key-here

# CORS origins (comma-separated)
CORS_ORIGINS=https://alphata.org,http://localhost:5173

# Session limits
MAX_SESSIONS=5
SESSION_IDLE_TIMEOUT=600

# JWT secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-string

# Coq paths (leave empty for auto-detection via PATH)
# COQC_PATH=/home/user/.opam/default/bin/coqc
# VSCOQTOP_PATH=/home/user/.opam/default/bin/vscoqtop
# COQLIB_PATH=

# Database (default: SQLite in project root)
# DATABASE_URL=sqlite+aiosqlite:///path/to/sf_learning.db

# Workspaces (per-user file storage)
# WORKSPACES_DIR=/var/www/sfwebsite/workspaces
